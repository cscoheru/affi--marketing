# Application
APP_NAME=affi-marketing-ai
APP_VERSION=1.0.0
ENVIRONMENT=development
DEBUG=true
API_HOST=0.0.0.0
API_PORT=8000

# CORS
CORS_ORIGINS=http://localhost:3000,http://localhost:5173,https://hub.zenconsult.top
CORS_ALLOW_CREDENTIALS=true

# Database
DATABASE_URL=postgresql+asyncpg://postgres:WhjQTPAwInc5Vav3sDWe@139.224.42.111:5432/business_hub
DATABASE_POOL_SIZE=20
DATABASE_MAX_OVERFLOW=10

# Redis
REDIS_URL=redis://:FWD4D75OKyQS7HOluA6J@139.224.42.111:6379/0
REDIS_CACHE_TTL=3600
REDIS_CACHE_PREFIX=affi_ai:

# AI API Keys
DASHSCOPE_API_KEY=sk-your-dashscope-key
OPENAI_API_KEY=sk-your-openai-key
CHATGLM_API_KEY=your-chatglm-key

# AI Model Configuration
DEFAULT_MODEL=qwen-turbo
FALLBACK_MODEL=gpt-3.5-turbo

# Model Costs (per 1M tokens)
COST_QWEN_TURBO_INPUT=0.0008
COST_QWEN_TURBO_OUTPUT=0.002
COST_QWEN_PLUS_INPUT=0.004
COST_QWEN_PLUS_OUTPUT=0.012
COST_GPT35_INPUT=0.0005
COST_GPT35_OUTPUT=0.0015
COST_GPT4_INPUT=0.03
COST_GPT4_OUTPUT=0.06
COST_CHATGLM_TURBO_INPUT=0.001
COST_CHATGLM_TURBO_OUTPUT=0.002
COST_CHATGLM_PLUS_INPUT=0.005
COST_CHATGLM_PLUS_OUTPUT=0.01

# Budget & Limits
DAILY_TOKEN_LIMIT=1000000
DAILY_COST_LIMIT=100
ALERT_THRESHOLD=80

# Content Generation
DEFAULT_MAX_TOKENS=2000
DEFAULT_TEMPERATURE=0.7
CONTENT_GENERATION_TIMEOUT=300
BATCH_SIZE=10

# SEO Configuration
DEFAULT_SEARCH_ENGINE=google
KEYWORD_RESEARCH_DEPTH=3
CONTENT_OPTIMIZATION_LEVEL=standard

# Affiliate Link Injection
MAX_LINKS_PER_ARTICLE=5
MIN_LINK_DISTANCE=200
LINK_INJECTION_SIMILARITY_THRESHOLD=0.7

# Monitoring
PROMETHEUS_PORT=9090
LOG_LEVEL=INFO
LOG_FORMAT=json

# Rate Limiting
RATE_LIMIT_PER_MINUTE=100
RATE_LIMIT_PER_HOUR=1000
