# Affi-Marketing Backend Service Environment Variables
# Copy this file to .env and fill in your values
#
# Railway Deployment Notes:
# - Railway automatically sets PORT environment variable
# - Use Railway Dashboard to set sensitive values (DB_PASSWORD, JWT_SECRET)
# - Set AI_SERVICE_URL to the deployed AI service URL

# Server Configuration
SERVER_PORT=8080
SERVER_HOST=0.0.0.0
SERVER_MODE=debug
# For production: set SERVER_MODE=release

# Database Configuration
DATABASE_HOST=139.224.42.111
DATABASE_PORT=5432
DATABASE_USER=postgres
DATABASE_PASSWORD=WhjQTPAwInc5Vav3sDWe
DATABASE_DB_NAME=business_hub
DATABASE_SSL_MODE=disable
DATABASE_MAX_OPEN_CONNS=100
DATABASE_MAX_IDLE_CONNS=10
DATABASE_CONN_MAX_LIFETIME=3600

# Redis Configuration
REDIS_HOST=139.224.42.111
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_DB=0
REDIS_POOL_SIZE=10

# JWT Configuration
JWT_SECRET=your-super-secret-key-change-this-in-production
JWT_EXPIRATION=24h
JWT_REFRESH_EXPIRATION=168h

# MinIO Configuration
MINIO_ENDPOINT=103.59.103.85:9000
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin
MINIO_BUCKET=affi-marketing
MINIO_USE_SSL=false

# AI Service Configuration
AI_SERVICE_URL=http://ai-api.zenconsult.top
AI_SERVICE_TIMEOUT=30s

# CORS Configuration
CORS_ALLOWED_ORIGINS=http://localhost:5173,https://hub.zenconsult.top
CORS_ALLOWED_METHODS=GET,POST,PUT,DELETE,OPTIONS
CORS_ALLOWED_HEADERS=*

# Logging Configuration
LOG_LEVEL=debug
LOG_OUTPUT=stdout
LOG_FORMAT=json

# Plugin Configuration
PLUGIN_TIMEOUT=30s
PLUGIN_MAX_MEMORY=512MB
